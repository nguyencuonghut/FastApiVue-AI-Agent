# Application
APP_NAME=FastApiVueBoilerplate
APP_ENV=development
APP_DEBUG=true
APP_TIMEZONE=Asia/Ho_Chi_Minh

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_HOST_PORT=8000
API_V1_PREFIX=/api/v1

# Frontend
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=5173
FRONTEND_HOST_PORT=5173
VITE_API_BASE_URL=/api/v1
VITE_PROXY_TARGET=http://127.0.0.1:8000
VITE_APP_TIMEZONE=Asia/Ho_Chi_Minh
VITE_AUTH_LOGGED_IN_COOKIE_NAME=fastapivue_logged_in
PROXY_HOST_PORT=8080

# Database
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=55432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/app
DATABASE_URL_FILE=

# Auth
JWT_SECRET_KEY=change-me
JWT_REFRESH_SECRET_KEY=change-me-too
JWT_SECRET_KEY_FILE=
JWT_REFRESH_SECRET_KEY_FILE=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_TOKEN_TRANSPORT=hybrid
AUTH_REFRESH_COOKIE_NAME=fastapivue_refresh_token
AUTH_REFRESH_COOKIE_SECURE=false
AUTH_REFRESH_COOKIE_SAMESITE=lax
AUTH_REFRESH_COOKIE_PATH=/api/v1/auth
AUTH_SEED_ADMIN_EMAIL=admin@fastapivue.local
AUTH_SEED_ADMIN_PASSWORD=change-me-admin-password
AUTH_SEED_UPDATE_ADMIN_PASSWORD=false

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ACCESS_KEY_FILE=
MINIO_SECRET_KEY_FILE=
MINIO_BUCKET=app-local
MINIO_CONSOLE_PORT=9001
MINIO_API_HOST_PORT=59000
MINIO_CONSOLE_HOST_PORT=59001

# SMTP Configuration (tested locally via Mailpit)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
SMTP_FROM_EMAIL=noreply@fastapivue.local
ADMIN_EMAIL_FOR_BACKUPS=admin@fastapivue.local

# CORS
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
LOG_LEVEL=INFO
LOG_FORMAT=json
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_ENABLED=false
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_LOGIN=5
RATE_LIMIT_FILES_UPLOAD=10
RATE_LIMIT_USERS_AVATAR_UPLOAD=10
RATE_LIMIT_USERS_IMPORT=5
RATE_LIMIT_USERS_EXPORT=10
OBSERVABILITY_ENABLED=true
METRICS_ENABLED=true
METRICS_PATH=/metrics
READINESS_PATH=/ready
OTEL_ENABLED=true
OTEL_SERVICE_NAME=fastapivue-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_EXPORTER_OTLP_HEADERS=
SLO_API_AVAILABILITY_TARGET=99.9
SLO_API_P95_MS=400
SLO_AUTH_LOGIN_P95_MS=500
SLO_IMPORT_JOB_SUCCESS_RATE=99.0
BACKUP_ROOT=./backups
BACKUP_RETENTION_DAYS=14

# Optional broker/cache
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
